{
  "name": "fantia-unpublish-tool",
  "version": "0.2.0",
  "description": "Fantia の自分の投稿を一括で非公開化／再公開できる Electron アプリ",
  "main": "dist/main.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "build": "tsc && copyfiles -u 1 \"src/renderer/**/*.{html,css}\" dist/",
    "start": "npm run build && env -u ELECTRON_RUN_AS_NODE electron .",
    "dev": "npm run build && env -u ELECTRON_RUN_AS_NODE electron .",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "copyfiles": "^2.4.1",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "typescript": "^5.4.0"
  },
  "build": {
    "appId": "com.fantia.unpublish.tool",
    "productName": "Fantia Unpublish Tool",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] }
      ]
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    }
  }
}
